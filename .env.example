# ── Alpaca (required for backtesting and --provider=alpaca) ──────────────────
ALPACA_API_KEY=
ALPACA_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── IBKR (required for --provider=ibkr) ──────────────────────────────────────
# IB Gateway must be running locally before starting the bot.
# Paper account ID format: DU1234567 (visible after logging into IB Gateway)
IBKR_ACCOUNT_ID=
IBKR_GATEWAY_URL=https://localhost:5055

# ── Tradovate (required for --provider=tradovate) ────────────────────────────
# API credentials are obtained from Account → API Access in the Tradovate platform.
# Generate TRADOVATE_DEVICE_ID once with: uuidgen
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=
TRADOVATE_CID=
TRADOVATE_SEC=
TRADOVATE_DEVICE_ID=
TRADOVATE_DEMO=true
# TRADOVATE_APP_VERSION=1.0

# ── General ───────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/brandon-bot.db
